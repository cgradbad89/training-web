@import "tailwindcss";

/*
 * Tailwind v4 reads design tokens from the `@theme` block below. Those
 * tokens reference regular CSS variables defined in `:root`, and the
 * dark-mode override block re-points the :root variables — which means
 * every utility class like `bg-card`, `text-textPrimary`, `border-border`
 * automatically flips to the dark palette without any component edits.
 */

:root {
  /* ── Light-mode design system tokens (defaults) ─────────────── */
  --background: #ffffff;
  --foreground: #111827;

  --color-textPrimary-raw:   #111827; /* gray-900 */
  --color-textSecondary-raw: #6b7280; /* gray-500 */

  --color-card-raw:    #ffffff;
  --color-surface-raw: #f9fafb; /* gray-50 */
  --color-border-raw:  #e5e7eb; /* gray-200 */

  --color-primary-raw:  #2563eb; /* blue-600  */
  --color-success-raw:  #16a34a; /* green-600 */
  --color-warning-raw:  #d97706; /* amber-600 — darkened from yellow-600 for WCAG AA 3:1 on white */
  --color-danger-raw:   #dc2626; /* red-600   */
  --color-recovery-raw: #6366f1; /* indigo-500 — for "deload" load badge */

  /* ── Chart color tokens (light) ─────────────────────────────── */
  --color-chart-primary-raw:        #2563eb; /* blue-600 — main data series */
  --color-chart-primary-muted-raw:  #93c5fd; /* blue-300 — inactive/background bars */
  --color-chart-secondary-raw:      #7c3aed; /* violet-700 — workout data */
  --color-chart-secondary-muted-raw:#c4b5fd; /* violet-300 */
  --color-chart-hr-raw:             #dc2626; /* red-600 — heart rate */
  --color-chart-success-raw:        #16a34a; /* green-600 — positive data */
  --color-chart-warning-raw:        #d97706; /* amber-600 — caution data */
  --color-chart-orange-raw:         #f97316; /* orange-500 — short runs / exercise */
  --color-chart-teal-raw:           #14b8a6; /* teal-500 — pilates / brush */
  --color-chart-cyan-raw:           #0891b2; /* cyan-600 — stand hours */
  --color-chart-grid-raw:           #e5e7eb; /* gray-200 — gridlines */
  --color-chart-axis-raw:           #6b7280; /* gray-500 — axis labels */
  --color-chart-tooltip-bg-raw:     #ffffff; /* tooltip background */

  /* Semantic level badge tokens */
  --color-level-great:      #dcfce7;
  --color-level-great-text: #15803d;
  --color-level-good:       #fef9c3;
  --color-level-good-text:  #a16207;
  --color-level-fair:       #ffedd5;
  --color-level-fair-text:  #c2410c;
  --color-level-poor:       #fee2e2;
  --color-level-poor-text:  #b91c1c;
}

@media (prefers-color-scheme: dark) {
  :root {
    /* ── Dark-mode token overrides ────────────────────────────── */
    --background: #0f172a; /* slate-900 */
    --foreground: #f1f5f9; /* slate-100 */

    --color-textPrimary-raw:   #f1f5f9; /* slate-100 */
    --color-textSecondary-raw: #94a3b8; /* slate-400 — ~5:1 on card */

    --color-card-raw:    #1e293b; /* slate-800 */
    --color-surface-raw: #0f172a; /* slate-900 (matches page background) */
    --color-border-raw:  #334155; /* slate-700 */

    /* Brighter brand/status colors for legibility on dark cards */
    --color-primary-raw:  #3b82f6; /* blue-500  */
    --color-success-raw:  #22c55e; /* green-500 */
    --color-warning-raw:  #eab308; /* yellow-500 */
    --color-danger-raw:   #ef4444; /* red-500   */
    --color-recovery-raw: #818cf8; /* indigo-400 */

    /* ── Chart color tokens (dark overrides) ──────────────────── */
    --color-chart-primary-raw:        #60a5fa; /* blue-400 — brighter on dark bg */
    --color-chart-primary-muted-raw:  #1e3a5f; /* deep navy — inactive bars */
    --color-chart-secondary-raw:      #a78bfa; /* violet-400 */
    --color-chart-secondary-muted-raw:#3b1f6e; /* deep violet */
    --color-chart-hr-raw:             #f87171; /* red-400 */
    --color-chart-success-raw:        #4ade80; /* green-400 */
    --color-chart-warning-raw:        #fbbf24; /* amber-400 */
    --color-chart-orange-raw:         #fb923c; /* orange-400 */
    --color-chart-teal-raw:           #2dd4bf; /* teal-400 */
    --color-chart-cyan-raw:           #22d3ee; /* cyan-400 */
    --color-chart-grid-raw:           #334155; /* slate-700 */
    --color-chart-axis-raw:           #94a3b8; /* slate-400 */
    --color-chart-tooltip-bg-raw:     #1e293b; /* slate-800 */

    /* Semantic level badge tokens — dark overrides */
    --color-level-great:      #14532d;
    --color-level-great-text: #4ade80;
    --color-level-good:       #713f12;
    --color-level-good-text:  #fbbf24;
    --color-level-fair:       #7c2d12;
    --color-level-fair-text:  #fdba74; /* orange-300 — lightened from orange-400 for WCAG AA 4.5:1 */
    --color-level-poor:       #7f1d1d;
    --color-level-poor-text:  #fca5a5; /* red-300 — lightened from red-400 for WCAG AA 4.5:1 */
  }
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --font-sans: var(--font-geist-sans);
  --font-mono: var(--font-geist-mono);

  /* Utility classes like bg-card resolve to these — pointed at the
     raw light/dark variables above so one prefers-color-scheme switch
     cascades through the whole app. */
  --color-textPrimary:   var(--color-textPrimary-raw);
  --color-textSecondary: var(--color-textSecondary-raw);

  --color-card:    var(--color-card-raw);
  --color-surface: var(--color-surface-raw);
  --color-border:  var(--color-border-raw);

  --color-primary:  var(--color-primary-raw);
  --color-success:  var(--color-success-raw);
  --color-warning:  var(--color-warning-raw);
  --color-danger:   var(--color-danger-raw);
  --color-recovery: var(--color-recovery-raw);

  /* Chart color tokens — referenced directly in Recharts color props */
  --color-chart-primary:        var(--color-chart-primary-raw);
  --color-chart-primary-muted:  var(--color-chart-primary-muted-raw);
  --color-chart-secondary:      var(--color-chart-secondary-raw);
  --color-chart-secondary-muted:var(--color-chart-secondary-muted-raw);
  --color-chart-pace:           var(--color-chart-primary-raw); /* alias */
  --color-chart-hr:             var(--color-chart-hr-raw);
  --color-chart-success:        var(--color-chart-success-raw);
  --color-chart-warning:        var(--color-chart-warning-raw);
  --color-chart-orange:         var(--color-chart-orange-raw);
  --color-chart-teal:           var(--color-chart-teal-raw);
  --color-chart-cyan:           var(--color-chart-cyan-raw);
  --color-chart-grid:           var(--color-chart-grid-raw);
  --color-chart-axis:           var(--color-chart-axis-raw);
  --color-chart-tooltip-bg:     var(--color-chart-tooltip-bg-raw);
}

body {
  background: var(--background);
  color: var(--foreground);
  font-family: var(--font-geist-sans, Arial, Helvetica, sans-serif);
}

/* Shared form input style */
.input {
  width: 100%;
  border: 1px solid var(--color-border);
  border-radius: 0.75rem;
  padding: 0.5rem 0.75rem;
  font-size: 0.875rem;
  background: var(--color-card);
  color: var(--color-textPrimary);
  outline: none;
}
.input:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 15%, transparent);
}
</file>

<file path="src/components/CalendarView.tsx">
"use client";

import React, { useState, useMemo } from "react";
import { useRouter } from "next/navigation";
import { ChevronLeft, ChevronRight } from "lucide-react";
import type { RunningPlan, WorkoutPlan } from "@/types/plan";
import type { HealthWorkout } from "@/types/healthWorkout";
import { buildCalendarEvents, type CalendarEvent } from "@/utils/planCalendar";
import { weekStart } from "@/utils/dates";
import { WeekCalendar, EventPill } from "@/components/WeekCalendar";

// ─── Date helpers ─────────────────────────────────────────────────────────────

function addDays(date: Date, n: number): Date {
  const d = new Date(date);
  d.setDate(d.getDate() + n);
  return d;
}

function isSameDay(a: Date, b: Date): boolean {
  return (
    a.getFullYear() === b.getFullYear() &&
    a.getMonth() === b.getMonth() &&
    a.getDate() === b.getDate()
  );
}

function todayMidnight(): Date {
  const d = new Date();
  d.setHours(0, 0, 0, 0);
  return d;
}

function getMonthStart(d: Date): Date {
  return new Date(d.getFullYear(), d.getMonth(), 1);
}

function weekPeriodLabel(monday: Date): string {
  const sunday = addDays(monday, 6);
  const opts: Intl.DateTimeFormatOptions = { month: "short", day: "numeric" };
  return `${monday.toLocaleDateString("en-US", opts)} – ${sunday.toLocaleDateString("en-US", opts)}`;
}

function monthPeriodLabel(d: Date): string {
  return d.toLocaleDateString("en-US", { month: "long", year: "numeric" });
}

// ─── Constants ────────────────────────────────────────────────────────────────

const DAY_HEADERS = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];

// ─── Month Grid ───────────────────────────────────────────────────────────────

function MonthGrid({
  events,
  monthStart,
  onEventClick,
}: {
  events: CalendarEvent[];
  monthStart: Date;
  onEventClick: (e: CalendarEvent) => void;
}) {
  const today = todayMidnight();
  const gridStart = weekStart(monthStart);
  const cells = Array.from({ length: 42 }, (_, i) => addDays(gridStart, i));

  return (
    <div className="overflow-y-auto flex-1">
      <div className="grid grid-cols-7 gap-px bg-border rounded-xl overflow-hidden border border-border">
        {/* Day name headers */}
        {DAY_HEADERS.map((h) => (
          <div key={h} className="p-2 text-center bg-card">
            <span className="text-xs font-semibold text-textSecondary">{h}</span>
          </div>
        ))}
        {/* Date cells */}
        {cells.map((day, i) => {
          const inMonth = day.getMonth() === monthStart.getMonth();
          const isToday = isSameDay(day, today);
          const dayEvents = events.filter((e) => isSameDay(e.date, day));
          const shown = dayEvents.slice(0, 3);
          const overflow = dayEvents.length - 3;
          return (
            <div key={i} className={`p-1.5 bg-card min-h-[72px] ${isToday ? "bg-primary/5" : ""}`}>
              <div
                className={`text-xs font-semibold mb-1 w-5 h-5 flex items-center justify-center rounded-full ${
                  isToday
                    ? "bg-primary text-white"
                    : inMonth
                    ? "text-textPrimary"
                    : "text-textSecondary/30"
                }`}
              >
                {day.getDate()}
              </div>
              <div className="flex flex-col gap-0.5">
                {shown.map((ev, j) => (
                  <EventPill key={j} event={ev} onClick={() => onEventClick(ev)} />
                ))}
                {overflow > 0 && (
                  <span className="text-[10px] text-textSecondary pl-1">+{overflow} more</span>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  );
}

// ─── Main Component ───────────────────────────────────────────────────────────

interface CalendarViewProps {
  plans: (RunningPlan | WorkoutPlan)[];
  actualRuns?: HealthWorkout[];
  onRunningEventClick?: (planId: string, weekIndex: number) => void;
}

export function CalendarView({ plans, actualRuns = [], onRunningEventClick }: CalendarViewProps) {
  const router = useRouter();

  const [calView, setCalView] = useState<"week" | "month">("week");
  const [currentMonday, setCurrentMonday] = useState<Date>(() => weekStart(new Date()));
  const [currentMonthStart, setCurrentMonthStart] = useState<Date>(() =>
    getMonthStart(new Date())
  );

  const events = useMemo(() => buildCalendarEvents(plans, actualRuns), [plans, actualRuns]);

  const hasActivePlans = plans.some((p) => p.isActive);

  const periodLabel =
    calView === "week"
      ? weekPeriodLabel(currentMonday)
      : monthPeriodLabel(currentMonthStart);

  function handlePrev() {
    if (calView === "week") {
      setCurrentMonday((d) => addDays(d, -7));
    } else {
      setCurrentMonthStart((d) => new Date(d.getFullYear(), d.getMonth() - 1, 1));
    }
  }

  function handleNext() {
    if (calView === "week") {
      setCurrentMonday((d) => addDays(d, 7));
    } else {
      setCurrentMonthStart((d) => new Date(d.getFullYear(), d.getMonth() + 1, 1));
    }
  }

  function handleEventClick(event: CalendarEvent) {
    if (event.planType === "workout") {
      router.push(
        `/workout/${event.planId}/${event.weekIndex}/${event.weekday}/${event.sessionIndex}`
      );
    } else if (onRunningEventClick) {
      onRunningEventClick(event.planId, event.weekIndex);
    } else {
      router.push("/plans");
    }
  }

  if (!hasActivePlans) {
    return (
      <div className="flex-1 flex items-center justify-center p-8">
        <p className="text-sm text-textSecondary text-center max-w-sm">
          No active plans. Activate a running or workout plan to see your schedule.
        </p>
      </div>
    );
  }

  return (
    <div className="flex flex-col flex-1 overflow-hidden p-4 gap-4">
      {/* Controls bar */}
      <div className="flex justify-between items-center shrink-0">
        <div className="flex gap-2">
          {(["week", "month"] as const).map((v) => (
            <button
              key={v}
              onClick={() => setCalView(v)}
              className={`px-4 py-1.5 rounded-full text-sm font-medium transition-colors capitalize ${
                calView === v
                  ? "bg-primary text-white"
                  : "text-textSecondary hover:text-textPrimary"
              }`}
            >
              {v}
            </button>
          ))}
        </div>
        <div className="flex items-center gap-2">
          <button
            onClick={handlePrev}
            className="p-1.5 rounded-lg hover:bg-surface text-textSecondary hover:text-textPrimary"
          >
            <ChevronLeft className="w-4 h-4" />
          </button>
          <span className="text-sm font-medium text-textPrimary min-w-[160px] text-center">
            {periodLabel}
          </span>
          <button
            onClick={handleNext}
            className="p-1.5 rounded-lg hover:bg-surface text-textSecondary hover:text-textPrimary"
          >
            <ChevronRight className="w-4 h-4" />
          </button>
        </div>
      </div>

      {calView === "week" ? (
        <WeekCalendar
          plans={plans}
          actualRuns={actualRuns}
          weekStart={currentMonday}
          onEventClick={handleEventClick}
        />
      ) : (
        <MonthGrid
          events={events}
          monthStart={currentMonthStart}
          onEventClick={handleEventClick}
        />
      )}
    </div>
  );
}
</file>

