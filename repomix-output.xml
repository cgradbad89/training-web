                    {r.distanceMiles.toFixed(2)} mi &middot;{" "}
                    {r.avgPaceSecPerMile
                      ? `${formatPace(r.avgPaceSecPerMile)} /mi`
                      : "\u2014"}
                  </span>
                </button>
              ))}
            </div>
          </div>
        )}
      </div>
    </div>
