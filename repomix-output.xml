          </div>
        </div>
      )}

      {/* ── Stats Grid ──────────────────────────────────────── */}
      <div className="bg-card rounded-2xl border border-border p-5">
        <div className="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-4 gap-5">
          <StatBlock
            label="Distance"
            value={
