  label,
  color,
  formatter,
  refValue,
  refLabel,
  type = "line",
  yDomain,
  yTickFormatter,
}: {
  data: { date: string; value: number | undefined }[];
  label: string;
  color: string;
  formatter?: (v: number) => string;
  refValue?: number;
  refLabel?: string;
