        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.userKey == resource.data.userKey
        && request.resource.data.scopeType == resource.data.scopeType
        && request.resource.data.matchValue == resource.data.matchValue
        && request.resource.data.createdFromTransactionId == resource.data.createdFromTransactionId
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.displayValue is string
        && request.resource.data.categoryKey is string
        && request.resource.data.categoryLabel is string
        && request.resource.data.updatedAt is timestamp;
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /budgetHousing/{housingId} {
      allow get: if budgetIsSignedIn()
        && housingId == "housing__" + budgetRequestUserKey();
      allow create: if housingId == "housing__" + budgetRequestUserKey()
        && budgetIsHousingDoc(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if housingId == "housing__" + budgetRequestUserKey()
