    }

    match /users/{uid}/pantry/root/groceryItems/{itemID} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.id is string
        && request.resource.data.name is string;
      allow update: if isOwner(uid) && request.resource.data.id == resource.data.id;
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/recipes/root/favorites/{recipeID} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/recipes/root/meta/{recipeID}/events/{eventID} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && request.resource.data.cookedAt is timestamp
        && optString('weekID') && optString('source') && optString('note')
        && optTimestamp('createdAt') && optTimestamp('updatedAt');
      allow update: if isOwner(uid)
        && request.resource.data.cookedAt is timestamp
        && request.resource.data.cookedAt == resource.data.cookedAt
        && optString('weekID') && optString('source') && optString('note')
        && optTimestamp('createdAt') && optTimestamp('updatedAt');
      allow delete: if isOwner(uid);
    }

    match /users/{uid}/recipes/root/meta/{recipeID} {
      allow read: if isOwner(uid);
      allow create, update: if isOwner(uid)
        && (!('recipeID' in request.resource.data) || request.resource.data.recipeID is string)
        && optString('note') && validRating() && optTimestamp('updatedAt');
      allow delete: if isOwner(uid);
    }

    match /sharedWeekPlans/{weekID}/users/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/pantry/root/savedGroceryItems/{itemId} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/recipeQueue/{docId} { allow read, write: if isOwner(uid); }

    match /recipes/{recipeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

		// ============================================================
    // CUSTOM CATEGORIES
    // ============================================================

    match /budgetCustomCategories/{categoryId} {
      allow read: if budgetOwnsData(resource.data);
      allow create: if budgetIsCustomCategoryDoc(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if budgetOwnsData(resource.data)
        && budgetPreservesOwner()
        && budgetIsCustomCategoryDoc(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
      allow delete: if budgetOwnsData(resource.data);
    }

    match /budgetMerchantCategoryRules/{ruleId} {
      allow read: if budgetOwnsData(resource.data);
      allow create: if budgetIsMerchantCategoryRuleDoc(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if budgetOwnsData(resource.data)
        && budgetPreservesOwner()
        && budgetIsMerchantCategoryRuleDoc(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
      allow delete: if budgetOwnsData(resource.data);
    }

    // ============================================================
    // END CUSTOM CATEGORIES
    // ============================================================

    // ============================================================
    // STOCK HOLDINGS
    // ============================================================

    match /budgetHoldings/{holdingId} {
      allow read: if budgetOwnsData(resource.data);
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.userKey is string
        && request.resource.data.accountId is string
        && request.resource.data.ticker is string
        && request.resource.data.shares is number
        && (request.resource.data.buyPrice == null
            || request.resource.data.buyPrice is number)
        && request.resource.data.isTSP is bool
        && request.resource.data.type is string
        && (!('notes' in request.resource.data)
            || request.resource.data.notes == null
            || request.resource.data.notes is string)
        && (!('cashAmount' in request.resource.data)
            || request.resource.data.cashAmount == null
            || request.resource.data.cashAmount is number)
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
      allow update: if budgetOwnsData(resource.data)
        && budgetPreservesOwner()
        && request.resource.data.accountId == resource.data.accountId
        && request.resource.data.ticker == resource.data.ticker
        && request.resource.data.shares is number
        && (request.resource.data.buyPrice == null
            || request.resource.data.buyPrice is number)
        && request.resource.data.isTSP is bool
        && request.resource.data.type is string
        && (!('notes' in request.resource.data)
            || request.resource.data.notes == null
            || request.resource.data.notes is string)
        && (!('cashAmount' in request.resource.data)
            || request.resource.data.cashAmount == null
            || request.resource.data.cashAmount is number)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp;
      allow delete: if budgetOwnsData(resource.data);
    }

    // ============================================================
    // END STOCK HOLDINGS
    // ============================================================

    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
