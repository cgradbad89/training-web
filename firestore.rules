        && request.resource.data.matchValue is string
        && request.resource.data.displayValue is string
        && request.resource.data.categoryKey is string
        && request.resource.data.categoryLabel is string
        && request.resource.data.createdFromTransactionId is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
      allow update: if isSignedIn()
