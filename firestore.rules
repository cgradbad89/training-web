        && request.resource.data.userKey is string
        && request.resource.data.year is number
        && request.resource.data.isActive is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && optNullableList('incomeRows') && optNullableList('savingsRows')
        && optNullableList('expenseRows') && optNullableList('accountRows')
        && optNullableList('charityRows')
        && optNullableString('notes');
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.userKey == resource.data.userKey
        && request.resource.data.year == resource.data.year
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.isActive is bool
        && request.resource.data.updatedAt is timestamp
        && optNullableList('incomeRows') && optNullableList('savingsRows')
        && optNullableList('expenseRows') && optNullableList('accountRows')
