    }

    match /budgetGoals/{goalId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.userKey is string
        && request.resource.data.title is string
        && request.resource.data.goalType in ['account_spending_cap','savings_target','payoff_goal','category_budget','net_worth_target','balance_target']
        && request.resource.data.scopeType in ['account','category','global']
        && request.resource.data.targetAmount is number
        && request.resource.data.cadence in ['monthly','custom']
        && request.resource.data.comparison in ['max','min']
        && request.resource.data.isActive is bool
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp
        && optNullableString('scopeId') && optNullableNumber('currentAmountOverride')
        && optNullableTimestampOrString('targetDate') && optNullableString('notes')
        && optNullableNumber('startingAccountAmount') && optNullableNumber('alreadySavedForGoal')
        && optNullableNumber('targetAccountTotal') && optNullableTimestampOrString('startingDate');
      allow update: if isSignedIn()
        && resource.data.ownerUid == request.auth.uid
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.userKey == resource.data.userKey
        && request.resource.data.goalType in ['account_spending_cap','savings_target','payoff_goal','category_budget','net_worth_target','balance_target']
        && request.resource.data.scopeType in ['account','category','global']
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.title is string
        && request.resource.data.targetAmount is number
        && request.resource.data.cadence in ['monthly','custom']
        && request.resource.data.comparison in ['max','min']
        && request.resource.data.isActive is bool
        && request.resource.data.updatedAt is timestamp
        && optNullableString('scopeId') && optNullableNumber('currentAmountOverride')
        && optNullableTimestampOrString('targetDate') && optNullableString('notes')
        && optNullableNumber('startingAccountAmount') && optNullableNumber('alreadySavedForGoal')
        && optNullableNumber('targetAccountTotal') && optNullableTimestampOrString('startingDate');
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /budgetManualTransactions/{transactionId} {
      allow read: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
      allow create: if budgetIsManualTransactionDoc(request.resource.data)
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;
      allow update: if budgetOwnsData(resource.data)
        && budgetPreservesOwner()
        && budgetIsManualTransactionDoc(request.resource.data)
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt == request.time;
      allow delete: if isSignedIn() && resource.data.ownerUid == request.auth.uid;
    }

    match /budgetAnnualPlans/{planId} {
